rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función para obtener el tenant_id del usuario desde su token personalizado
    function getUserTenantId() {
      return request.auth.token.tenant_id;
    }

    // Función para verificar si el usuario pertenece al tenant del documento
    function isSameTenant(resourceData) {
      return isAuthenticated() && getUserTenantId() == resourceData.tenant_id;
    }

    // Reglas para la colección de Trámites (Submissions)
    match /submissions/{submissionId} {
      allow read: if isSameTenant(resource.data);
      allow create: if isAuthenticated() && request.resource.data.tenant_id == getUserTenantId();
      allow update, delete: if isSameTenant(resource.data);
    }

    // Reglas para la colección de Formularios (Forms)
    match /forms/{formId} {
      // Los formularios públicos se pueden leer sin auth si están publicados
      allow read: if resource.data.publico == true || isSameTenant(resource.data);
      allow create: if isAuthenticated() && request.resource.data.tenant_id == getUserTenantId();
      allow update, delete: if isSameTenant(resource.data);
    }

    // Reglas para la configuración del Tenant (Branding, etc)
    match /tenants/{tenantId} {
      allow read: if isAuthenticated() && (getUserTenantId() == tenantId || tenantId == 'public');
      allow write: if isAuthenticated() && getUserTenantId() == tenantId && request.auth.token.role == 'admin';
    }

    // Reglas para Notificaciones
    match /Notifications/{notificationId} {
      allow read: if isSameTenant(resource.data);
      allow create, update: if isAuthenticated(); // El sistema o workflows crean notificaciones
      allow delete: if isSameTenant(resource.data);
    }

    // Bloqueo por defecto para cualquier otra colección
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
