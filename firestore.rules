rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función para verificar si es un super administrador
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'super_admin' || 
        request.auth.token.email == 'modernizacionsancarlos@gmail.com'
      );
    }

    // Función para obtener el tenant_id del usuario
    function getUserTenantId() {
      return request.auth.token.tenant_id;
    }

    // Función para verificar si el usuario pertenece al tenant del documento
    function isSameTenant(resourceData) {
      return isSuperAdmin() || (isAuthenticated() && getUserTenantId() == resourceData.tenant_id);
    }

    // Documento de formulario: referencia en envíos públicos anónimos
    function formSchemaData(formId) {
      return get(/databases/$(database)/documents/FormSchemas/$(formId)).data;
    }
    function formSchemaExists(formId) {
      return exists(/databases/$(database)/documents/FormSchemas/$(formId));
    }
    // Crea trámite sin sesión: solo si el formulario es público y acepta respuestas, y el tenant_id coincide
    function canCreatePublicAnonymousSubmission() {
      return !isAuthenticated() &&
        request.resource.data.keys().hasAll(['schema_id', 'tenant_id', 'data', 'status', 'created_by']) &&
        formSchemaExists(request.resource.data.schema_id) &&
        formSchemaData(request.resource.data.schema_id).is_public == true &&
        (!formSchemaData(request.resource.data.schema_id).keys().hasAll(['accepts_responses']) ||
         formSchemaData(request.resource.data.schema_id).accepts_responses == true) &&
        (
          (formSchemaData(request.resource.data.schema_id).keys().hasAll(['tenant_id']) &&
            request.resource.data.tenant_id == formSchemaData(request.resource.data.schema_id).tenant_id) ||
          (!formSchemaData(request.resource.data.schema_id).keys().hasAll(['tenant_id']) &&
            request.resource.data.tenant_id == 'global')
        );
    }

    // Trámites (Submissions). Nota: tras un delete, getDoc puede consultar un ID sin documento; si la regla
    // solo usa resource.data, no existe y la lectura falla (falso permission-denied / bloqueos en el cliente).
    match /Submissions/{submissionId} {
      function submissionPathExists() {
        return exists(/databases/$(database)/documents/Submissions/$(submissionId));
      }
      // get: seguimiento público (portal ciudadano) — quien posea el ID puede leer ese documento; el ID no es enumerable.
      //      Consultas list siguen restringidas a personal autenticado (no filtrar todo en anónimo).
      allow get: if isSuperAdmin() ||
        (isAuthenticated() && !submissionPathExists()) ||
        (isAuthenticated() && resource != null && isSameTenant(resource.data)) ||
        (!isAuthenticated() && submissionPathExists());
      // list: nunca anónimo; filtrado por tenant vía isSameTenant en cada fila.
      allow list: if isSuperAdmin() || (isAuthenticated() && isSameTenant(resource.data));
      allow create: if canCreatePublicAnonymousSubmission() ||
        (isAuthenticated() && (
        isSuperAdmin() || 
        request.resource.data.tenant_id == getUserTenantId() ||
        (getUserTenantId() == null)
      ));
      // Incluye trámites con tenant_id "global" (formularios públicos viejos) o sin campo, para personal con tenant
      // no bloquear borrado frente a isSameTenant; super_admin y mismo tenant siguen prioridad.
      allow update, delete: if isSameTenant(resource.data)
        || (isAuthenticated() && getUserTenantId() != null
          && (resource.data.tenant_id == "global" || !resource.data.keys().hasAll(["tenant_id"])));
    }

    // Reglas para la colección de Formularios (FormSchemas)
    match /FormSchemas/{formId} {
      allow read: if resource.data.is_public == true || isSameTenant(resource.data);
      allow create: if isSuperAdmin() || (isAuthenticated() && getUserTenantId() != null);
      allow update, delete: if isSameTenant(resource.data);
    }

    // Reglas para la configuración del Tenant (tenants)
    match /tenants/{tenantId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || getUserTenantId() == tenantId);
      allow write: if isSuperAdmin() || (isAuthenticated() && getUserTenantId() == tenantId && request.auth.token.role == 'admin');
    }

    // Reglas para Perfiles de Usuario
    match /userProfiles/{email} {
      allow read: if isSuperAdmin() || (isAuthenticated() && request.auth.token.email.lower() == email.lower());
      allow create: if isAuthenticated() && request.auth.token.email.lower() == email.lower();
      allow update: if isSuperAdmin() || (
        isAuthenticated() && 
        request.auth.token.email.lower() == email.lower() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'tenant_id', 'permissions'])
      );
      allow delete: if isSuperAdmin();
    }

    // Reglas para Auditoría (AuditLogs)
    match /AuditLogs/{logId} {
      allow read: if isSameTenant(resource.data);
      allow create: if isAuthenticated() && (isSuperAdmin() || request.resource.data.tenant_id == getUserTenantId());
      allow update, delete: if isSuperAdmin();
    }

    // Reglas para Comunicación (CommunicationLogs) - NUEVO
    match /CommunicationLogs/{logId} {
      allow read: if isSameTenant(resource.data);
      allow create: if isAuthenticated() && (isSuperAdmin() || request.resource.data.tenant_id == getUserTenantId());
      allow update, delete: if isSuperAdmin();
    }

    // Reglas para Notificaciones - NUEVO
    match /Notifications/{notifId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        request.auth.uid == resource.data.userId || 
        getUserTenantId() == resource.data.tenant_id
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // Bloqueo por defecto para seguridad máxima
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
