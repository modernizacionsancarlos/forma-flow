rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Perfil de app en Firestore (misma fuente que el cliente); el ID es el email en minúsculas.
    function hasUserProfile() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/userProfiles/$(request.auth.token.email.lower()));
    }
    function userProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.token.email.lower())).data;
    }

    // Super admin: custom claims O email legacy O perfil en userProfiles (sin depender solo del JWT)
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.email == 'modernizacionsancarlos@gmail.com' ||
        (hasUserProfile() && userProfile().keys().hasAll(['role']) && userProfile().role == 'super_admin')
      );
    }

    // Tenant efectivo: claim tenant_id o tenantId en userProfiles (alineado con AuthContext)
    function getUserTenantId() {
      return (request.auth.token.keys().hasAll(['tenant_id']) && request.auth.token.tenant_id != null)
        ? request.auth.token.tenant_id
        : (hasUserProfile() && userProfile().keys().hasAll(['tenantId']) ? userProfile().tenantId : null);
    }

    // Puede administrar un tenant (admin de empresa) según claim o perfil
    function isProfileTenantAdmin() {
      return hasUserProfile() && userProfile().keys().hasAll(['role']) &&
        (userProfile().role == 'admin' || userProfile().role == 'admin_empresa');
    }
    function isTokenTenantAdmin() {
      return request.auth.token.keys().hasAll(['role']) && request.auth.token.role == 'admin';
    }

    // Mismo tenant: envíos y form usan tenant_id; áreas, workflows, exports, invitations usan tenantId
    function isSameTenant(resourceData) {
      return isSuperAdmin() || (isAuthenticated() && getUserTenantId() != null && (
        (resourceData.keys().hasAll(['tenant_id']) && getUserTenantId() == resourceData.tenant_id) ||
        (resourceData.keys().hasAll(['tenantId']) && getUserTenantId() == resourceData.tenantId)
      ));
    }

    // Documento de formulario: referencia en envíos públicos anónimos
    function formSchemaData(formId) {
      return get(/databases/$(database)/documents/FormSchemas/$(formId)).data;
    }
    function formSchemaExists(formId) {
      return exists(/databases/$(database)/documents/FormSchemas/$(formId));
    }
    // Crea trámite sin sesión: solo si el formulario es público y acepta respuestas, y el tenant_id coincide
    function canCreatePublicAnonymousSubmission() {
      return !isAuthenticated() &&
        request.resource.data.keys().hasAll(['schema_id', 'tenant_id', 'data', 'status', 'created_by']) &&
        formSchemaExists(request.resource.data.schema_id) &&
        formSchemaData(request.resource.data.schema_id).is_public == true &&
        (!formSchemaData(request.resource.data.schema_id).keys().hasAll(['accepts_responses']) ||
         formSchemaData(request.resource.data.schema_id).accepts_responses == true) &&
        (
          (formSchemaData(request.resource.data.schema_id).keys().hasAll(['tenant_id']) &&
            request.resource.data.tenant_id == formSchemaData(request.resource.data.schema_id).tenant_id) ||
          (!formSchemaData(request.resource.data.schema_id).keys().hasAll(['tenant_id']) &&
            request.resource.data.tenant_id == 'global')
        );
    }

    // Trámites (Submissions). Nota: tras un delete, getDoc puede consultar un ID sin documento; si la regla
    // solo usa resource.data, no existe y la lectura falla (falso permission-denied / bloqueos en el cliente).
    match /Submissions/{submissionId} {
      function submissionPathExists() {
        return exists(/databases/$(database)/documents/Submissions/$(submissionId));
      }
      // get: seguimiento público (portal ciudadano) — quien posea el ID puede leer ese documento; el ID no es enumerable.
      //      Consultas list siguen restringidas a personal autenticado (no filtrar todo en anónimo).
      allow get: if isSuperAdmin() ||
        (isAuthenticated() && !submissionPathExists()) ||
        (isAuthenticated() && resource != null && isSameTenant(resource.data)) ||
        (!isAuthenticated() && submissionPathExists());
      // list: nunca anónimo; filtrado por tenant vía isSameTenant en cada fila.
      allow list: if isSuperAdmin() || (isAuthenticated() && isSameTenant(resource.data));
      allow create: if canCreatePublicAnonymousSubmission() ||
        (isAuthenticated() && (
        isSuperAdmin() || 
        request.resource.data.tenant_id == getUserTenantId() ||
        (getUserTenantId() == null)
      ));
      // Incluye trámites con tenant_id "global" (formularios públicos viejos) o sin campo, para personal con tenant
      // no bloquear borrado frente a isSameTenant; super_admin y mismo tenant siguen prioridad.
      allow update, delete: if isSameTenant(resource.data)
        || (isAuthenticated() && getUserTenantId() != null
          && (resource.data.tenant_id == "global" || !resource.data.keys().hasAll(["tenant_id"])));
    }

    // Reglas para la colección de Formularios (FormSchemas)
    match /FormSchemas/{formId} {
      allow read: if resource.data.is_public == true || isSameTenant(resource.data);
      allow create: if isSuperAdmin() || (isAuthenticated() && getUserTenantId() != null);
      allow update, delete: if isSameTenant(resource.data);
    }

    // Configuración global de la app (matriz de permisos por rol en cliente)
    match /systemConfig/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Reglas para la configuración del Tenant (tenants)
    match /tenants/{tenantId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || getUserTenantId() == tenantId);
      allow write: if isSuperAdmin() || (
        isAuthenticated() &&
        getUserTenantId() == tenantId &&
        (isTokenTenantAdmin() || isProfileTenantAdmin())
      );
    }

    // Alta de perfil por administradores del mismo tenant (o super_admin).
    // docId es el ID del documento en userProfiles (mismo correo en minúsculas).
    function userProfileCreatePayloadValid(docId) {
      return request.resource.data.keys().hasAll(['email', 'tenantId', 'role']) &&
        request.resource.data.email is string &&
        request.resource.data.email.lower() == docId.lower();
    }
    function canStaffCreateOtherUserProfile(docId) {
      return isAuthenticated() && hasUserProfile() &&
        userProfile().keys().hasAll(['role', 'tenantId']) &&
        (userProfile().role == 'admin' || userProfile().role == 'admin_empresa') &&
        userProfileCreatePayloadValid(docId) &&
        getUserTenantId() != null &&
        getUserTenantId() == request.resource.data.tenantId;
    }

    /** Admin de tenant: ajustar solo excepciones de permisos en otro usuario del mismo tenant */
    function tenantStaffCanOverridePermissions(targetEmail) {
      return isAuthenticated() && hasUserProfile() &&
        (userProfile().role == 'admin' || userProfile().role == 'admin_empresa') &&
        exists(/databases/$(database)/documents/userProfiles/$(targetEmail)) &&
        get(/databases/$(database)/documents/userProfiles/$(targetEmail)).data.tenantId == getUserTenantId();
    }

    function onlyPermissionOverrideKeysChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['permission_grant','permission_revoke']);
    }

    // Reglas para Perfiles de Usuario
    match /userProfiles/{email} {
      allow read: if isSuperAdmin() || (isAuthenticated() && request.auth.token.email.lower() == email.lower());
      allow create: if (isSuperAdmin() && userProfileCreatePayloadValid(email)) ||
        (isAuthenticated() && request.auth.token.email.lower() == email.lower()) ||
        canStaffCreateOtherUserProfile(email);
      allow update: if isSuperAdmin() || (
        isAuthenticated() && 
        request.auth.token.email.lower() == email.lower() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'tenant_id', 'permissions'])
      ) || (
        tenantStaffCanOverridePermissions(email) && onlyPermissionOverrideKeysChanged()
      );
      allow delete: if isSuperAdmin();
    }

    // Reglas para Auditoría (AuditLogs)
    match /AuditLogs/{logId} {
      allow read: if isSameTenant(resource.data);
      allow create: if isAuthenticated() && (isSuperAdmin() || request.resource.data.tenant_id == getUserTenantId());
      allow update, delete: if isSuperAdmin();
    }

    // Reglas para Comunicación (CommunicationLogs) - NUEVO
    match /CommunicationLogs/{logId} {
      allow read: if isSameTenant(resource.data);
      allow create: if isAuthenticated() && (isSuperAdmin() || request.resource.data.tenant_id == getUserTenantId());
      allow update, delete: if isSuperAdmin();
    }

    // Reglas para Notificaciones - NUEVO
    match /Notifications/{notifId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        request.auth.uid == resource.data.userId || 
        getUserTenantId() == resource.data.tenant_id
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // Colecciones adicionales (áreas, workflows, exports, invitations, …): acceso por tenant o super
    // En create, resource aún no existe: usar request.resource
    match /{document=**} {
      allow get, list: if isSuperAdmin() ||
        (isAuthenticated() && resource != null && isSameTenant(resource.data));
      allow create: if isSuperAdmin() ||
        (isAuthenticated() && isSameTenant(request.resource.data));
      allow update, delete: if isSuperAdmin() ||
        (isAuthenticated() && resource != null && isSameTenant(resource.data) &&
          isSameTenant(request.resource.data));
    }
  }
}
