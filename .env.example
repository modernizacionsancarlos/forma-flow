# ====================================
# FormaFlow - Variables de Entorno
# ====================================
# Copia este archivo como .env y completá los valores reales:
#   cp .env.example .env
#
# Obtener valores desde: https://console.firebase.google.com/project/TU_PROYECTO/settings/general
# VAPID Key desde: Firebase Console > Cloud Messaging > Web Push certificates > Par de claves

VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# Región de Cloud Functions (debe coincidir con functions/index.js, por defecto us-east1)
VITE_FIREBASE_FUNCTIONS_REGION=us-east1
# Opcional: URL pública del sitio (enlaces en correos y restablecimiento de contraseña)
# VITE_PUBLIC_APP_URL=https://tu-dominio.web.app
# Opcional: POST de copia de correo a n8n/Make (si no usás solo el correo de Firebase)
# VITE_EMAIL_WEBHOOK_URL=
# Desarrollo: emulador de Functions (firebase emulators:start --only functions)
# VITE_USE_FUNCTIONS_EMULATOR=true
VITE_FIREBASE_VAPID_KEY=tu_vapid_key_publica_aqui
